{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sharpedge.system/contracts/v2/eyes_audit_event.schema.json",
  "title": "EyesAuditEventV2",
  "description": "Sealed local audit event used for review decisions, lease lifecycle, and runtime authority decisions.",
  "type": "object",
  "properties": {
    "contract_version": { "const": "2.0.0" },
    "event_id": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": [
        "review_decision",
        "lease_minted",
        "tool_allowed",
        "tool_blocked",
        "tool_failed",
        "lease_consumed",
        "anomaly_detected",
        "lease_revoked",
        "leases_revoked"
      ]
    },
    "principal_id": { "type": ["string", "null"] },
    "lease_id": { "type": ["string", "null"] },
    "capability": { "type": ["string", "null"] },
    "tool_name": { "type": ["string", "null"] },
    "outcome": { "type": ["string", "null"] },
    "reason": { "type": "string" },
    "details": { "type": "object", "additionalProperties": true },
    "timestamp": { "type": "string", "format": "date-time" },
    "timestamp_ns": { "type": "integer", "minimum": 0 },
    "previous_event_sha256": { "type": ["string", "null"] },
    "event_sha256": { "type": "string" }
  },
  "required": [
    "contract_version",
    "event_id",
    "event_type",
    "principal_id",
    "lease_id",
    "capability",
    "tool_name",
    "outcome",
    "reason",
    "details",
    "timestamp",
    "timestamp_ns",
    "previous_event_sha256",
    "event_sha256"
  ],
  "additionalProperties": false
}
