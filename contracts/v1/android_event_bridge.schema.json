{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sharpedge.system/contracts/v1/android_event_bridge.schema.json",
  "title": "AndroidEventBridgeV1",
  "description": "Append-only DroidPuppy event envelope for Android-native facts flowing into Project OS.",
  "type": "object",
  "properties": {
    "schema_version": { "const": "android.event_bridge.v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "topic": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "timestamp",
    "topic",
    "event_type",
    "source",
    "payload"
  ],
  "additionalProperties": false
}
